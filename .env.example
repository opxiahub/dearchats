OPENAI_API_KEY=sk-...
# Override which OpenAI models drive the pipeline. Leave unset to use the defaults below.
# OPENAI_MAIN_MODEL powers taste-heavy roles (curator, narrator, year synthesizer).
# OPENAI_MINI_MODEL powers bulk/utility roles (scout, cartographer, historian, opening scribe).
# OPENAI_VISION_MODEL is the photo classifier (falls back to OPENAI_MINI_MODEL, then gpt-4o-mini).
OPENAI_MAIN_MODEL=gpt-5.4
OPENAI_MINI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-4o-mini
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
PORT=3000
# Max upload size in megabytes. Defaults to 250 if unset.
NEXT_PUBLIC_MAX_UPLOAD_MB=250
